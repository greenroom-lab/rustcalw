{
  "env": {
    "vars": {
      "MY_CUSTOM_VAR": "hello"
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "auth": {
      "mode": "token",
      "token": "test-token-placeholder"
    },
    "reload": {
      "mode": "hybrid",
      "debounceMs": 300
    }
  },
  "logging": {
    "level": "info",
    "consoleStyle": "pretty",
    "redactSensitive": "tools"
  },
  "session": {
    "scope": "per-sender",
    "typingMode": "thinking",
    "idleMinutes": 30,
    "reset": {
      "mode": "daily",
      "atHour": 4
    },
    "maintenance": {
      "mode": "warn",
      "maxEntries": 500
    }
  },
  "agents": {
    "defaults": {
      "model": "test-provider/test-model"
    },
    "list": [
      {
        "id": "default",
        "default": true,
        "name": "TestBot",
        "identity": {
          "name": "TestBot",
          "emoji": "🤖"
        }
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "test-provider": {
        "baseUrl": "https://api.example.com/v1",
        "apiKey": "test-api-key-placeholder",
        "api": "openai-completions",
        "models": [
          {
            "id": "test-model",
            "name": "Test Model",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0.001,
              "output": 0.002,
              "cacheRead": 0.0005,
              "cacheWrite": 0.001
            },
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "channels": {
    "defaults": {
      "groupPolicy": "allowlist"
    },
    "discord": {
      "enabled": true,
      "token": "test-discord-token",
      "groupPolicy": "allowlist"
    }
  },
  "messages": {
    "ackReaction": "👀",
    "ackReactionScope": "group-mentions"
  },
  "hooks": {
    "enabled": false
  }
}
